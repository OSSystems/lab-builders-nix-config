#!/bin/sh
#
# OE custom terminal wrapper for the NixOS + bubblewrap (yocto-env) build.
#
# Why this exists
# ---------------
# BitBake's interactive tasks (do_menuconfig, do_devshell, do_diffconfig, ...)
# open a terminal by running the auto-generated run.do_terminal script through
# OE_TERMINAL. That script begins with "#!/bin/bash".
#
# Our build runs inside a bubblewrap container provided by the O.S. Systems
# "yocto-env" Nix package; inside it /bin/bash exists. The tmux *server*,
# however, lives on the bare NixOS host (outside the container), where there is
# no /bin/bash. So the default tmux terminals (tmux / tmux-running /
# tmux-new-window) spawn the script on the host and it dies immediately with:
#
#     run.do_terminal: /bin/bash: bad interpreter: No such file or directory
#
# (do_menuconfig then "Succeeds" instantly without ever showing the UI.)
#
# Fix
# ---
# Run the task on a SEPARATE tmux server (socket "oe-build") started from inside
# the container, so its windows inherit the container's /bin/bash. If we are
# already inside the user's tmux, surface it as a new window that attaches to
# that server; otherwise print how to attach.
#
# Wired up via build/conf/local.conf:
#     OE_TERMINAL = "custom"
#     OE_TERMINAL_CUSTOMCMD = ".../oe-nix-terminal {command}"

SOCK="oe-build"
SESSION="bb-$$"

# {command} expands to: oe-gnome-terminal-phonehome <pidfile> <run.do_terminal>
# Start it detached on the container-side tmux server. phonehome records the
# real task PID into <pidfile>, which BitBake then monitors to know when the
# interactive task finishes -- so do_menuconfig blocks until you close the menu.
tmux -L "$SOCK" new-session -d -s "$SESSION" -x 220 -y 55 "$@" || exit $?

if [ -n "$TMUX" ]; then
    # Inside the user's tmux: pop open a window attached to the task session.
    tmux new-window -n "$SESSION" "exec tmux -L $SOCK attach -t $SESSION" || true
else
    echo "BitBake terminal started. Attach with:  tmux -L $SOCK attach -t $SESSION"
fi

exit 0
